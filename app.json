{
  "expo": {
    "name": "AIExpenseTrackerOffline",
    "slug": "AIExpenseTrackerOffline",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiexpensetrackeroffline",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.aiexpensetracker.offline"
    },
    "android": {
      "package": "com.aiexpensetracker.offline",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["READ_SMS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "extraMavenRepos": [],
            "packagingOptions": {
              "pickFirst": ["**/libc++_shared.so"]
            },
            "cppFlags": "-std=c++20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5da27dd-a323-4762-840c-e2f67cbdda59"
      }
    },
    "owner": "rohitgaidhane"
  }
}
