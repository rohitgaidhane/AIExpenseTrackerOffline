{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "downlevelIteration": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2015", "dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["example", "node_modules"]
}
